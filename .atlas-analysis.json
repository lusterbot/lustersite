  "keyFeatures": [
    "Server moderation with ban, kick, mute, timeout, and hardban commands",
    "AntiNuke protection against mass role/channel deletion, bans, and bot invasions",
    "AutoMod with blocked words, invite filtering, and spam detection",
    "Customizable welcome/leave messages with rich embed builders",
    "VoiceMaster for user-controlled temporary voice channels",
    "Ticket system for server support management",
    "XP-based leveling system with role rewards",
    "Full economy system with jobs, gambling, and trading",
    "Last.fm integration for music scrobbling and stats",
    "Giveaway system with configurable entries and winners",
    "Starboard for community-highlighted messages",
    "AutoRole for automatic role assignment on member join",
    "Premium tier with AI chat, image recognition, and OCR features",
    "Custom prefix configuration per server",
    "Bump reminders for server listing bots"
  ],
